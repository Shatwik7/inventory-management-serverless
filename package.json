{
  "name": "shop-inventory-api",
  "version": "1.0.0",
  "description": "Hexagonal TypeScript shop inventory API with auth, tax and excel support",
  "main": "dist/lambda.js",
  "scripts": {
    "lint": "npm run check",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand",
    "test:e2e": "jest tests/e2e --runInBand",
    "deploy": "serverless deploy",
    "dev": "serverless dev"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.836.0",
    "@aws-sdk/lib-dynamodb": "^3.836.0",
    "jsonwebtoken": "^9.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.152",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.3",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.3"
  }
}
